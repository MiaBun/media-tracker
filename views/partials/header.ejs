<header class="main-header">
    <nav class="nav-cointainer">
        <div class="logo">
            <a href="/">MediaTracker</a>
        </div>
        <ul class="nav-links">
            <li><a href="/movies-tv" class="<%= currentPage === 'movies-tv' ? 'active' : '' %>">🎬 Movies/TV</a></li>
            <li><a href="/books-manga" class="<%= currentPage === 'books-manga' ? 'active' : '' %>">📚 Books/Manga</a></li>
            <li><a href="/games" class="<%= currentPage === 'games' ? 'active' : '' %>">🎮 Games</a></li>
            <li><a href="/calendar" class="<%= currentPage === 'calendar' ? 'active' : '' %>">📅 Calendar <span id="notification-badge" class="notification-badge" style="display: none;">0</span></a></li>
        </ul>
        <div class="nav-search">
            <input type="text" id="globalSearch" placeholder="Search...">
            <div id="searchResults" class="search-results" style="display: none;"></div>
        </div>
    </nav>
</header>

<style>
    .main-header {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        padding: 15px 30px;
        position: sticky;
        top: 0;
        z-index: 1000;
        box-shadow: 0 2px 20px rgba(0,0,0,0.3);
    }

    .nav-container {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .logo a {
        font-size: 1.5em;
        font-weight: bold;
        color: #667eea;
        text-decoration: none;
    }

    .nav-links {
        display: flex;
        list-style: none;
        gap: 30px;
    }

    .nav-links a {
        color: #999;
        text-decoration: none;
        font-size: 0.95em;
        transition: color 0.3s;
        padding: 5px 10px;
        border-radius: 5px;
    }

    .nav-links a:hover,
    .nav-links a.active {
        color: #fff;
        background: rgba(102, 126, 234, 0.2);
    }

    .nav-search {
        position: relative;
    }

    .nav-search input {
        padding: 8px 15px;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 20px;
        color: white;
        width: 250px;
    }

    .notification-badge {
        background: #ff4444;
        color: white;
        border-radius: 50%;
        padding: 2px 6px;
        font-size: 0.7em;
        margin-left: 5px;
    }

    .search-results {
        position: absolute;
        top: 100%;
        right: 0;
        width: 350px;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 10px;
        max-height: 400px;
        overflow-y: auto;
        margin-top: 10px;
    }

    @media (max-width: 768px) {
        .nav-links {
            gap: 15px;
            font-size: 0.85em;
        }
    
        .nav-search input {
            width: 150px;
        }
    }
</style>

<script>
// Global search functionality
let searchTimeout;
document.getElementById('globalSearch').addEventListener('input', function(e) {
    clearTimeout(searchTimeout);
    const query = e.target.value;
    
    if (query.length < 2) {
        document.getElementById('searchResults').style.display = 'none';
        return;
    }
    
    searchTimeout = setTimeout(async () => {
        try {
            const response = await fetch(`/api/search?q=${query}`);
            const results = await response.json();
            
            const resultsDiv = document.getElementById('searchResults');
            resultsDiv.innerHTML = results.map(item => `
                <div class="search-result-item" onclick="window.location.href='/${item.media_category}'">
                    <img src="${item.cover_image || '/images/placeholder.jpg'}" 
                         alt="${item.title}" 
                         style="width: 40px; height: 40px; object-fit: cover;">
                    <div>
                        <strong>${item.title}</strong>
                        <small>${item.media_category.replace('_', ' ')}</small>
                    </div>
                </div>
            `).join('');
            
            resultsDiv.style.display = results.length ? 'block' : 'none';
        } catch (error) {
            console.error('Search error:', error);
        }
    }, 300);
});

// Fetch notification count
async function updateNotificationBadge() {
    try {
        const response = await fetch('/calendar/api/upcoming-count');
        const data = await response.json();
        const badge = document.getElementById('notification-badge');
        if (data.count > 0) {
            badge.textContent = data.count;
            badge.style.display = 'inline';
        }
    } catch (error) {
        console.error('Error fetching notifications:', error);
    }
}

updateNotificationBadge();
setInterval(updateNotificationBadge, 3600000); // Update every hour
</script>